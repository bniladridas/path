{
  "version": 2,
  "builds": [
    {
      "src": "apps/web/__init__.py",
      "use": "@vercel/python"
    },
    {
      "src": "packages/ui/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/packages/ui/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/apps/web/__init__.py"
    }
  ],
  "env": {
    "PYTHONPATH": "."
  }
}
